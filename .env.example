# ─── Application ────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ecomagent:ecomagent@db:5432/ecomagent

# ─── Redis / Celery ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── LLM — fill in at least one ──────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic | gemini | ollama
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Amazon SP-API ────────────────────────────────────────────────
# Apply at: https://developer-docs.amazon.com/sp-api/
AMAZON_CLIENT_ID=amzn1.application-oa2-client...
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER   # US marketplace
AMAZON_REGION=us-east-1
AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# ─── Amazon Advertising API ──────────────────────────────────────
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
AMAZON_ADS_PROFILE_ID=

# ─── Scraping ────────────────────────────────────────────────────
SCRAPER_PROXY_URL=          # optional: http://user:pass@host:port
SCRAPER_HEADLESS=true
