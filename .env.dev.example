# EcomAgent Local Development Config
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.dev (git-ignored) and fill in your API keys.
# Used for local real-LLM testing only. Never commit .env.dev.
#
# Run real LLM tests:
#   source .env.dev && pytest tests/real_llm/ -v -m real_llm -s

# ─── LLM (yunwu-compatible OpenAI endpoint) ──────────────────────────────────
OPENAI_BASE_URL=https://yunwu.ai/v1

# Choose ONE key based on the model you want to test with:
#   GPT series    → use YUNWU_GPT_KEY value
#   Claude series → use YUNWU_CLAUDE_KEY value
#   Gemini series → use YUNWU_GEMINI_KEY value
OPENAI_API_KEY=<paste-yunwu-key-here>

# Model to use for real LLM tests (no evaluation comment — just a config choice)
OPENAI_MODEL=gpt-4o

# ─── Local infra ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./dev.db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
SECRET_KEY=dev-local-secret-not-for-production

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LLM_PROVIDER=openai
